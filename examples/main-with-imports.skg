# main-with-imports.skg - import statement demo
#
# Imports pull in another .skg file before the rest of this file is
# parsed. Paths are relative to the file containing the import.
# Later values overwrite earlier ones, so the main file always wins.
#
# Use imports to split shared config (theme, keybinds) from per-host
# config. Circular imports are an error.

skg_version: "1.0"

# Array form - ordered, processed top to bottom
import [
  "./theme.skg",
  "./users.skg",
]

# Single import form is also valid:
#     import "./theme.skg"

# Override a value the import set. Because this runs after the imports,
# it wins. Keeps the shared file as a default without forking it.
theme {
  accent: "purple"
}

# Colonless scalar array shorthand - equivalent to:
#     hostnames: ["alpha", "beta", "gamma"]
hostnames ["alpha", "beta", "gamma"]

# Null explicitly unsets an inherited value. Useful when an imported
# file set something you don't want in this deployment.
cache_ttl: null

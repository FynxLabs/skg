{
  "name": "tree-sitter-skg",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the SKG config format",
  "license": "Apache-2.0",
  "main": "bindings/node",
  "keywords": ["parser", "tree-sitter", "skg", "dusk"],
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.20.8"
  },
  "scripts": {
    "build": "tree-sitter generate && node-gyp rebuild",
    "test": "tree-sitter test"
  },
  "tree-sitter": [
    {
      "scope": "source.skg",
      "file-types": ["skg"],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm"
    }
  ]
}
